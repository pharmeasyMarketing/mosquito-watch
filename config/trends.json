  "sanity": {
    "_comment": "Data-quality guard rails (same fail-loud philosophy as Layer 1). The build aborts and writes nothing if no national series is produced, if more than max_fail_fraction of groups fail nationally, if any series has fewer than min_points_per_series points, or if fewer than min_nonzero_fraction of all returned values are non-zero (a likely sign the query or provider broke).",
    "max_fail_fraction": 0.5,
    "min_points_per_series": 4,
    "min_nonzero_fraction": 0.05
  }
