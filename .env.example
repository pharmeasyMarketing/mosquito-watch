# Copy this file to ".env" (or "apify.env") in the same folder and fill in your
# real token(s). Any *.env file is gitignored, so secrets never get committed or
# shown in chat. The Layer 2 providers read these automatically.

# --- Apify (the "apify" Trends provider) -----------------------------------
# Get tokens at: https://console.apify.com/settings/integrations
# Add as many as you like; failover uses them in this order and rotates to the
# next when one runs low on monthly budget (or hits a self-imposed cap).
APIFY_TOKEN=apify_api_primary_token_here
# APIFY_TOKEN_2=apify_api_backup_token_here
# APIFY_TOKEN_3=apify_api_another_backup
# ...or, equivalently, a single list:
# APIFY_TOKENS=apify_api_primary, apify_api_backup, apify_api_another

# Optional failover/budget knobs (sensible defaults if omitted):
# APIFY_MIN_RESERVE_USD=0.10          # switch when a token's monthly budget drops below this
# APIFY_MAX_SPEND_PER_TOKEN_USD=5.00  # our self-measured spend cap per token before rotating
# APIFY_EST_RUN_COST_USD=0.05         # assumed per-run cost before the first real run is measured

# --- SerpApi (the "serpapi" provider) --------------------------------------
# Get keys at: https://serpapi.com/manage-api-key
# Same multi-key failover as Apify: rotates to the next key when one runs low on
# its monthly search quota. Trial keys are capped at 250 searches/month each.
SERPAPI_KEY=your_primary_serpapi_key_here
# SERPAPI_KEY_2=your_backup_serpapi_key_here
# ...or a single list:  SERPAPI_KEYS=key_a, key_b
# Optional failover knobs:
# SERPAPI_MIN_RESERVE=3              # switch when fewer than this many searches remain
# SERPAPI_MAX_SEARCHES_PER_KEY=240  # our self-measured cap per key before rotating

# To make a real provider the default (instead of mock) without passing --provider:
# TRENDS_PROVIDER=serpapi
