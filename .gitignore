# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Logs / scratch output
*.log

# Layer 3 season PDF cache (downloaded IDSP weekly reports; large + re-fetchable).
# The aggregated data/confirmed_season.json is committed; these raw PDFs are not.
data/cache/

# Secrets -- API tokens/keys for Layer 2 real providers (Apify, SerpApi, ...).
# Put APIFY_TOKEN / SERPAPI_KEY here as KEY=value lines; never commit them.
# `*.env` covers .env and apify.env; .env.example ends in .example so it stays tracked.
.env
*.env
*.local.json
.secrets/

# NOTE: data/*.json (data.json, fever_signal.json, confirmed_cases.json) are
# intentionally NOT ignored -- the GitHub Actions cron commits the regenerated
# data files so the static dashboard can read them.
#
# NOTE: tests/fixtures/idsp/*.pdf is intentionally tracked too -- a real saved
# IDSP weekly report is the offline `fixture` source + the parser regression
# fixture (Layer 3). It is a small one-off binary, committed on purpose.
